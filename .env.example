# Example environment variables - copy to .env and fill in values

# Flask
SECRET_KEY=your-secret-key-here

# Database (optional, defaults to database/vm_tips.db)
# DATABASE_PATH=/path/to/database.db

# Email (Brevo/Sendinblue)
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-username
MAIL_PASSWORD=your-brevo-password
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# Football Data API
FOOTBALL_API_KEY=your-football-data-api-key

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=generate-with-werkzeug

# Application URL
APP_URL=http://localhost:5000
